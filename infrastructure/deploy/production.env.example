# Copy to production.env on the server (gitignored). Do not commit secrets.
# Pin the image (Compose substitutes ${CAT_ID_IMAGE} from shell or a project .env file;
# if you set CAT_ID_IMAGE below, run: docker compose --env-file production.env pull && docker compose --env-file production.env up -d)
# CAT_ID_IMAGE=rg.fr-par.scw.cloud/cat-id/app:v1.0.0
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
LASTFM_API_KEY=your_lastfm_api_key_here
APP_ENV=production
APP_BASE_URL=https://app.cat-id.eu
SPOTIFY_REDIRECT_URI=https://app.cat-id.eu/api/spotify/callback
ALLOWED_ORIGINS=https://app.cat-id.eu
ENABLE_DEBUG_ENDPOINT=false
PORT=8000
