# Copy to scw-registry.local.env (gitignored) and fill in values.
# Never commit scw-registry.local.env.

SCW_SECRET_KEY=
# Optional (Docker login to Scaleway CR usually only needs the secret key):
# SCW_ACCESS_KEY=

# Registry / image (defaults match a namespace named "cat-id" in fr-par):
# SCW_REGION=fr-par
# SCW_REGISTRY_NAMESPACE=cat-id
# Image repo name under the namespace (avoids cat-id/cat-id duplication):
# SCW_IMAGE_NAME=app
