SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
LASTFM_API_KEY=your_lastfm_api_key_here

# Runtime mode: development | production
APP_ENV=development

# Base URL of the currently running app (local or public domain)
APP_BASE_URL=https://localhost:8000

# Must match an allowed redirect in your Spotify app settings
SPOTIFY_REDIRECT_URI=https://localhost:8000/api/spotify/callback

# Comma-separated CORS origins. Keep this explicit in production.
ALLOWED_ORIGINS=https://localhost:8000,http://localhost:8000

# Keep diagnostic endpoints disabled outside local debugging
ENABLE_DEBUG_ENDPOINT=true

# ---- Production on server (Docker): use infrastructure/compose/env/production.env ----
# ---- Production example (Scaleway + custom domain) ----
# APP_ENV=production
# APP_BASE_URL=https://app.cat-id.eu
# SPOTIFY_REDIRECT_URI=https://app.cat-id.eu/api/spotify/callback
# ALLOWED_ORIGINS=https://app.cat-id.eu
# ENABLE_DEBUG_ENDPOINT=false
#
# ---- Staging example (same server, separate hostname/stack) ----
# APP_ENV=production
# APP_BASE_URL=https://staging.app.cat-id.eu
# SPOTIFY_REDIRECT_URI=https://staging.app.cat-id.eu/api/spotify/callback
# ALLOWED_ORIGINS=https://staging.app.cat-id.eu
# ENABLE_DEBUG_ENDPOINT=false
